{
  "name": "weather-engine-root",
  "version": "1.0.0",
  "description": "Root package to run both backend and frontend locally",
  "scripts": {
    "install:all": "cd frontend-react && npm install --legacy-peer-deps",
    "dev:frontend": "cd frontend-react && npm run dev",
    "dev:backend": ". venv/bin/activate && uvicorn api:app --reload --port 8000",
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev": "npm start",
    "build": "cd frontend-react && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
